# Copy this file to terraform.tfvars and fill in the values you want to
# override from variables.tf defaults. terraform.tfvars is gitignored.
#
# Defaults that you almost certainly want to keep:
#   aws_region          = "eu-north-1"
#   instance_type       = "t3.micro"
#   root_volume_size_gb = 10
#   github_owner        = "tenderi"
#   github_repo         = "diplomacy"
#   budget_monthly_usd  = 5

# --- SSH access (optional) ---
# If you want SSH alongside SSM, create a key pair in the AWS console
# (or with `aws ec2 create-key-pair`) and set the name here. Leave both
# unset to skip — Session Manager will still work.
#
# key_name         = "your-key-pair-name"
# allowed_ssh_cidr = "203.0.113.42/32"  # YOUR public IP only

# --- Budget alerts (optional but recommended) ---
# Leave empty to skip. With a value, AWS Budgets emails at 80% and 100% of
# budget_monthly_usd.
#
# budget_alert_email = "you@example.com"
